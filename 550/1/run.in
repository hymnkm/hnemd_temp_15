potential    nep.txt
velocity     550

ensemble     npt_ber 300 300 1000 0 10 500
time_step    1
dump_thermo  1000
dump_position 10000
run          500000

ensemble nvt_nhc 300 300 500
time_step    1
dump_thermo  1000
dump_position 10000
run          500000

# HNEMD production run, x-direction
ensemble     nvt_nhc 300 300 500
compute_hnemd  1000 5.0e-4 0 0
compute_shc 1 1000 0 1000 120.0
dump_position 10000
run          2500000